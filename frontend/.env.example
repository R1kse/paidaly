# Для браузера (dev-сервер на этой же машине)
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# Для Android-сборки — замените на локальный IP вашего ПК в WiFi-сети
# (узнать: ipconfig → IPv4, например 192.168.1.42)
# VITE_API_URL=http://192.168.1.42:3000
# VITE_WS_URL=http://192.168.1.42:3000
